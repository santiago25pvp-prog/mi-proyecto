{
  "name": "mi-proyecto",
  "version": "1.8.0",
  "description": "Express backend service for mi-proyecto",
  "main": "dist/server.js",
  "scripts": {
    "test": "node --test --require ts-node/register tests/admin-auth.test.ts tests/api-routes.test.ts",
    "test:backend": "node --test --require ts-node/register tests/admin-auth.test.ts tests/api-routes.test.ts",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc -p tsconfig.json",
    "start-server": "ts-node server.ts",
    "start": "node dist/server.js",
    "admin:set-role": "ts-node scripts/set-admin.ts",
    "auth:get-token": "ts-node scripts/get-token.ts",
    "auth:verify": "ts-node scripts/verify-auth.ts",
    "rag:qa": "ts-node scripts/qa-rag.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": "20.18.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "2.101.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "22.19.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "^5.8.2"
  }
}
