{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "incremental": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "server.ts",
    "backend/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "frontend",
    "node_modules"
  ]
}
